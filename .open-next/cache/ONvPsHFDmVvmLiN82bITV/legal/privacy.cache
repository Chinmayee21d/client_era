]]\n10:I[6869,[],\"IconMark\"]\n8:null\nd:[[\"$\",\"title\",\"0\",{\"children\":\"Privacy Policy | Client Era\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"How Client Era collects, uses, and protects your business and operational data.\"}],[\"$\",\"meta\",\"2\",{\"name\":\"author\",\"content\":\"ClientEra\"}],[\"$\",\"link\",\"3\",{\"rel\":\"manifest\",\"href\":\"/manifest.webmanifest\",\"crossOrigin\":\"$undefined\"}],[\"$\",\"meta\",\"4\",{\"name\":\"keywords\",\"content\":\"CRM,sales software,field sales,commercial OS,AI sales platform,pipeline management,sales intelligence\"}],[\"$\",\"meta\",\"5\",{\"name\":\"creator\",\"content\":\"ClientEra\"}],[\"$\",\"meta\",\"6\",{\"name\":\"robots\",\"content\":\"index, follow\"}],[\"$\",\"link\",\"7\",{\"rel\":\"canonical\",\"href\":\"https://clientera.aio/legal/privacy\"}],[\"$\",\"meta\",\"8\",{\"property\":\"og:title\",\"content\":\"Privacy Policy | Client Era\"}],[\"$\",\"meta\",\"9\",{\"property\":\"og:description\",\"content\":\"How Client Era collects, uses, and protects your business and operational data.\"}],[\"$\",\"meta\",\"10\",{\"property\":\"og:url\",\"content\":\"https://clientera.aio/legal/privacy\"}],[\"$\",\"meta\",\"11\",{\"property\":\"og:type\",\"content\":\"article\"}],[\"$\",\"meta\",\"12\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"13\",{\"name\":\"twitter:title\",\"content\":\"ClientEra — The Unified Commercial OS\"}],[\"$\",\"meta\",\"14\",{\"name\":\"twitter:description\",\"content\":\"One platform for your entire commercial relationship — from the first conversation to the last payment.\"}],[\"$\",\"meta\",\"15\",{\"name\":\"twitter:image\",\"content\":\"https://www.clientera/logo.png\"}],[\"$\",\"link\",\"16\",{\"rel\":\"icon\",\"href\":\"/favicon.ico?603d046c9a6fdfbb\",\"type\":\"image/x-icon\",\"sizes\":\"16x16\"}],[\"$\",\"link\",\"17\",{\"rel\":\"icon\",\"href\":\"/logo.png\"}],[\"$\",\"link\",\"18\",{\"rel\":\"apple-touch-icon\",\"href\":\"/logo.png\"}],[\"$\",\"$L10\",\"19\",{}]]\n11:I[8500,[\"500\",\"static/chunks/500-c99b8dfd3de17c86.js\",\"476\",\"static/chunks/app/legal/%5Bslug%5D/page-15bc5f6386411560.js\"],\"\"]\n:HL[\"/logo.png\",\"image\"]\n12:Tb9e,<h1>Client Era Privacy Policy</h1>\n<p><strong>Last Updated: March 2026</strong></p>\n<p>Client Era (&quot;we,&quot; &quot;us,&quot; or &quot;our&quot;) operates the clientera.com B2B operations and distributor management platform. This Privacy Policy details how we handle the personal and corporate data we collect when you use our platform.</p>\n<h2>1. Information We Collect</h2>\n<h3>A. Operational Data</h3>\n<p>Because we are a B2B platform, the primary data we collect is related to supply chain and operational efficiency:</p>\n<ul>\n<li><strong>Corporate Contact Info:</strong> Names, email addresses, and phone numbers of authorized users (distributors, sales managers, dispatchers).</li>\n<li><strong>Transactional Records:</strong> Sales orders (SORs), proforma invoices, pricing agreements, and fulfillment tracking logs.</li>\n</ul>\n<h3>B. Technical Data</h3>\n<ul>\n<li>IP addresses, browser types, and device identifiers required to secure the platform.</li>\n<li>System activity logs, session durations, and interaction metrics used to optimize platform functionality.</li>\n</ul>\n<h2>2. How We Use Information</h2>\n<p>Client Era processes data to:</p>\n<ul>\n<li>Authenticate authorized users and enforce role-based access controls across our modules.</li>\n<li>Facilitate B2B commerce (e.g., executing SORs, notifying distributors of ETA updates).</li>\n<li>Maintain service security, prevent fraud, and maintain comprehensive audit trails.</li>\n<li>Analyze operational bottlenecks to improve our software routing and algorithms.</li>\n</ul>\n<h2>3. Data Sharing and Sub-processors</h2>\n<p>We do not sell operational or personal data to third parties. We only share information with:</p>\n<ul>\n<li><strong>Sub-processors:</strong> Essential infrastructure providers (e.g., AWS, Vercel) bound by strict data processing agreements.</li>\n<li><strong>Your Organization:</strong> Actions performed by users (e.g., a Sales Manager) are visible to authorized personnel within the same organization based on defined permissions.</li>\n<li><strong>Legal Compliance:</strong> Law enforcement or regulatory bodies, only when legally required.</li>\n</ul>\n<h2>4. Data Security</h2>\n<p>Client Era employs enterprise-grade security, including:</p>\n<ul>\n<li>Encryption of data in transit (TLS 1.3) and at rest (AES-256).</li>\n<li>Strict infrastructure access controls and role-based operational permissions.</li>\n<li>Regular vulnerability scanning and independent security audits.</li>\n</ul>\n<h2>5. Your Rights</h2>\n<p>Depending on your jurisdiction, you or your organization may have the right to:</p>\n<ul>\n<li>Access, rectify, or erase your personal operational data.</li>\n<li>Withdraw consent for non-essential data processing.</li>\n<li>Request an export of your transaction history.</li>\n</ul>\n<p>To exercise these rights, please contact your organization&#39;s Platform Administrator or email us at <strong><a href=\"mailto:privacy@clientera.com\">privacy@clientera.com</a></strong>.</p>\n5:[\"$\",\"main\",null,{\"style\":{\"background\":\"var(--navy)\",\"minHeight\":\"100vh\",\"color\":\"var(--text)\",\"display\":\"flex\",\"flexDirection\":\"column\"},\"children\":[[\"$\",\"header\",null,{\"style\":{\"width\":\"100%\",\"padding\":\"24px clamp(24px, 5vw, 64px)\",\"borderBottom\":\"1px solid rgba(255,255,255,0.1)\",\"display\":\"flex\",\"alignItems\":\"center\",\"justifyContent\":\"space-between\",\"position\":\"sticky\",\"top\":0,\"zIndex\":100,\"backdropFilter\":\"blur(10px)\",\"background\":\"rgba(11,22,40,0.85)\"},\"children\":[[\"$\",\"$L11\",null,{\"href\":\"/\",\"style\":{\"display\":\"flex\",\"alignItems\":\"center\",\"gap\":\"6px\",\"textDecoration\":\"none\"},\"children\":[\"$\",\"img\",null,{\"src\":\"/logo.pn