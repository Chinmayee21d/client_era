lex:1\"><div style=\"font-size:8px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:1px;margin-bottom:3px\">Expense Claim</div><div style=\"font-size:13px;font-weight:600;color:var(--text);margin-bottom:2px\">₹4,200 — Client travel, Pune</div><div style=\"font-size:11px;color:var(--text3)\">from <!-- -->Raj K.<!-- --> · <!-- -->6h ago</div></div><span style=\"font-size:9px;font-weight:700;padding:3px 10px;border-radius:100px;background:rgba(24,184,122,.1);color:var(--green);border:1px solid var(--green)30;margin-left:8px\">₹4,200</span></div><div style=\"display:flex;gap:6px;flex-wrap:wrap\"><button class=\"sm-appr-btn\" style=\"background:var(--green);color:#fff\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"10\" height=\"10\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check-big\" aria-hidden=\"true\" style=\"margin-right:4px;vertical-align:-1px\"><path d=\"M21.801 10A10 10 0 1 1 17 3.335\"></path><path d=\"m9 11 3 3L22 4\"></path></svg>Approve</button><button class=\"sm-appr-btn\" style=\"background:rgba(255,255,255,.08);color:var(--text2)\">Hold</button><button class=\"sm-appr-btn\" style=\"background:rgba(245,166,35,.12);color:#F5A623\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"10\" height=\"10\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-rotate-ccw\" aria-hidden=\"true\" style=\"margin-right:4px;vertical-align:-1px\"><path d=\"M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8\"></path><path d=\"M3 3v5h5\"></path></svg>Rework</button></div></div></div></div></div></div></div></section>   <section class=\"section-dark\"><style>\n        .sm-coach-chat-msg {\n          padding: 10px 14px; border-radius: 12px;\n          max-width: 85%; font-size: 12px; line-height: 1.55;\n        }\n        .sm-coach-grid {\n          display: grid;\n          grid-template-columns: 1fr 1fr;\n          gap: 24px;\n          transition-delay: .15s;\n        }\n        @media (max-width: 1024px) {\n          .sm-coach-grid {\n            display: flex;\n            flex-direction: column;\n            gap: 24px;\n          }\n          .sm-coach-scatter { height: 180px !important; }\n        }\n      </style><div class=\"wrap\"><div class=\"reveal\" style=\"text-align:center;margin-bottom:48px;max-width:650px;margin:0 auto 48px\"><div class=\"eyebrow\" style=\"justify-content:center\"><span class=\"ey-line\"></span>Coaching &amp; Performance</div><h2 class=\"h2\" style=\"text-align:center\">Coach smarter.<br/><em>Not louder.</em></h2><p class=\"lead\" style=\"margin:0 auto;text-align:center\">Correlate activity to results. See which reps work hard vs. work smart. Then have a conversation backed by data, not assumptions.</p></div><div class=\"reveal sm-coach-grid\"><div class=\"sm-coach-dashboard\" style=\"background:var(--surface);border:1px solid var(--border);border-radius:18px;padding:24px 22px\"><div style=\"display:flex;align-items:center;gap:8px;margin-bottom:16px\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-activity\" aria-hidden=\"true\" style=\"color:var(--gold)\"><path d=\"M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.25.25 0 0 1-.48 0L9.24 2.18a.25.25 0 0 0-.48 0l-2.35 8.36A2 2 0 0 1 4.49 12H2\"></path></svg><span style=\"font-size:10px;font-weight:700;color:var(--gold);text-transform:uppercase;letter-spacing:1.5px\">Activity-to-Result Efficiency</span></div><div class=\"sm-coach-scatter\" style=\"position:relative;height:200px;border-left:1px solid var(--border);border-bottom:1px solid var(--border);margin-bottom:8px\"><div style=\"position:absolute;bottom:-20px;left:50%;transform:translateX(-50%);f