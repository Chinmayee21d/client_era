ht:40px;border-radius:10px;background:#3470F015;color:#3470F0;display:flex;align-items:center;justify-content:center\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-user-plus\" aria-hidden=\"true\"><path d=\"M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2\"></path><circle cx=\"9\" cy=\"7\" r=\"4\"></circle><line x1=\"19\" x2=\"19\" y1=\"8\" y2=\"14\"></line><line x1=\"22\" x2=\"16\" y1=\"11\" y2=\"11\"></line></svg></div><div style=\"align-self:center\"><div style=\"font-size:14px;font-weight:700;color:var(--text)\">Lead Management</div></div></a><a style=\"display:flex;gap:16px;text-decoration:none;padding:12px 16px;border-radius:14px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.05)\" href=\"/sales-ops\"><div style=\"width:40px;height:40px;border-radius:10px;background:#C49A3C15;color:#C49A3C;display:flex;align-items:center;justify-content:center\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chart-column\" aria-hidden=\"true\"><path d=\"M3 3v16a2 2 0 0 0 2 2h16\"></path><path d=\"M18 17V9\"></path><path d=\"M13 17V5\"></path><path d=\"M8 17v-3\"></path></svg></div><div style=\"align-self:center\"><div style=\"font-size:14px;font-weight:700;color:var(--text)\">Order to Cash</div></div></a><a style=\"display:flex;gap:16px;text-decoration:none;padding:12px 16px;border-radius:14px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.05)\" href=\"/sales-management\"><div style=\"width:40px;height:40px;border-radius:10px;background:#18B87A15;color:#18B87A;display:flex;align-items:center;justify-content:center\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-target\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><circle cx=\"12\" cy=\"12\" r=\"6\"></circle><circle cx=\"12\" cy=\"12\" r=\"2\"></circle></svg></div><div style=\"align-self:center\"><div style=\"font-size:14px;font-weight:700;color:var(--text)\">Sales and Engagement</div></div></a><a style=\"display:flex;gap:16px;text-decoration:none;padding:12px 16px;border-radius:14px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.05)\" href=\"/customer-support\"><div style=\"width:40px;height:40px;border-radius:10px;background:#9C40F015;color:#9C40F0;display:flex;align-items:center;justify-content:center\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-question-mark\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3\"></path><path d=\"M12 17h.01\"></path></svg></div><div style=\"align-self:center\"><div style=\"font-size:14px;font-weight:700;color:var(--text)\">Customer Excellence</div></div></a></div><div style=\"margin-top:40px\"><p style=\"font-size:10px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:2px;margin-bottom:16px\">More</p><a style=\"display:block;padding:12px 0;font-size:16px;color:var(--text2);font-weight:500;border-bottom:1px solid rgba(255,255,255,0.05)\" href=\"/#ai-layer\">AI Layer</a><a style=\"display:block;padding:12px 0;font-size:16px;color:var(--text2);font-weight:500;border-bottom:1px solid rgba(255,255,255,0.05)\" href=\"/#pricing\">Pricing</a><a style=\"display:block;padding:12px 0;font-size:16px;color:var(--text2);font-weight:500;border-bottom:1px solid rgba(255,255,255,0.05)\" href=\"/#comparison\">Why ClientEra</a></div></div><div style=\"margin-top:auto;padding:32px;display:flex;flex-direction:column;gap:12px\"><a href=\"#\" class=\"btn-ghost\" style=\"justify-content:center;padding:14px\">Log in</a><button class=\"btn-gold\" style=\"justify-content:center;padding:14px;cursor:pointer;border:none\">Book a Demo</button></div></div><main style=\"flex:1;padding-top:80px\"><section id=\"faq\" style=\"background:var(--navy);padding:clamp(60px, 8vw, 120px) 24px;position:relative;overflow:hidden\"><style>\n        .faq-item {\n          border-bottom: 1px solid rgba(255,255,255,0.08);\n          padding: 24px 0;\n        }\n        .faq-item:first-of-type {\n          border-top: 1px solid rgba(255,255,255,0.08);\n        }\n        .faq-q {\n          font-size: clamp(16px, 1.5vw, 20px);\n          font-weight: 600;\n          color: var(--text);\n          cursor: pointer;\n          list-style: none; /* Hide default arrow */\n          position: relative;\n          padding-right: 30px;\n        }\n        .faq-q::-webkit-details-marker {\n          display: none;\n        }\n        .faq-q::after {\n          content: '+';\n          position: absolute;\n          right: 0;\n          top: 50%;\n          transform: translateY(-50%);\n          font-size: 24px;\n          color: var(--gold);\n          font-weight: 300;\n          transition: transform 0.3s;\n        }\n        details[open] .faq-q::after {\n          content: '−';\n        }\n        .faq-a {\n          padding-top: 16px;\n          font-size: 15px;\n          line-height: 1.6;\n          color: var(--text3);\n          max-width: 800px;\n        }\n      </style><div style=\"position:absolute;top:-100px;right:-100px;width:600px;height:600px;background:radial-gradient(ellipse,rgba(196,154,60,.08) 0%,transparent 70%);pointer-events:none\"></div><div style=\"max-width:880px;margin:0 auto;position:relative;z-index:10\"><div style=\"margin-bottom:56px\"><div class=\"eyebrow\" style=\"color:var(--gold);margin-bottom:16px\"><span style=\"width:18px;height:1px;background:var(--gold)\"></span>Frequently Asked Questions</div><h2 class=\"h2 h2-white\" style=\"margin-bottom:16px\">Answers to your <em style=\"color:var(--gold);font-style:italic;font-weight:300\">questions.</em></h2><p class=\"lead\" style=\"color:var(--text2)\">Common questions about Client Era&#x27;s platform, implementation, and features.</p></div><div class=\"faq-list\"><details class=\"faq-item\"><summary class=\"faq-q\">What makes Client Era different from generic CRM systems?</summary><p class=\"faq-a\">Client Era is purpose-built for the B2B supply chain. Unlike generic CRMs (like Salesforce or HubSpot), our platform features native order workflows, proforma invoice management, dispatch planning, and localized distributor targets built directly into the system out of the box.</p></details><details class=\"faq-item\"><summary class=\"faq-q\">How long does implementation take?</summary><p class=\"faq-a\">Most organizations complete their pilot rollout in 2 to 4 weeks. Because Client Era utilizes a predefined logical data schema for Sales Operations, setup is accelerated compared to open-ended implementations.</p></details><details class=\"faq-item\"><summary class=\"faq-q\">Can distributors place orders from their mobile phones?</summary><p class=\"faq-a\">Yes. The Distributor Portal is fully responsive and supports mobile devices, allowing external partners to submit SORs, check fulfillment statuses, and upload payment receipts directly from the field without a native app download.</p></details><details class=\"faq-item\"><summary class=\"faq-q\">Does it integrate with our existing ERP (e.g., SAP, Oracle)?</summary><p class=\"faq-a\">Yes. Client Era is designed to sit on top of your existing ERP. We provide secure APIs and batch CSV mechanisms to push confirmed Dispatch Plans to the ERP and pull ERP shipping statuses back to the Dispatcher Terminal.</p></details><details class=\"faq-item\"><summary class=\"faq-q\">What kind of security and compliance do you offer?</summary><p class=\"faq-a\">We use enterprise-grade encryption for data in transit and at rest, enforce strict role-based access control (RBAC), and maintain comprehensive audit trails for every state change (e.g., pricing approvals, manifest dispatches). We align with GDPR and DPDP Act standards for corporate data.</p></details><details class=\"faq-item\"><summary class=\"faq-q\">Do you charge per distributor seat?</summary><p class=\"faq-a\">No. We understand that scale is critical in distributor networks. Licensing is based on your internal operational volume or internal seats, allowing infinite external distributor logins to maximize portal adoption.</p></details></div><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"What makes Client Era different from generic CRM systems?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Client Era is purpose-built for the B2B supply chain. Unlike generic CRMs (like Salesforce or HubSpot), our platform features native order workflows, proforma invoice management, dispatch planning, and localized distributor targets built directly into the system out of the box.\"}},{\"@type\":\"Question\",\"name\":\"How long does implementation take?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Most organizations complete their pilot rollout in 2 to 4 weeks. Because Client Era utilizes a predefined logical data schema for Sales Operations, setup is accelerated compared to open-ended implementations.\"}},{\"@type\":\"Question\",\"name\":\"Can distributors place orders from their mobile phones?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. The Distributor Portal is fully responsive and supports mobile devices, allowing external partners to submit SORs, check fulfillment statuses, and upload payment receipts directly from the field without a native app download.\"}},{\"@type\":\"Question\",\"name\":\"Does it integrate with our existing ERP (e.g., SAP, Oracle)?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Client Era is designed to sit on top of your existing ERP. We provide secure APIs and batch CSV mechanisms to push confirmed Dispatch Plans to the ERP and pull ERP shipping statuses back to the Dispatcher Terminal.\"}},{\"@type\":\"Question\",\"name\":\"What kind of security and compliance do you offer?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"We use enterprise-grade encryption for data in transit and at rest, enforce strict role-based access control (RBAC), and maintain comprehensive audit trails for every state change (e.g., pricing approvals, manifest dispatches). We align with GDPR and DPDP Act standards for corporate data.\"}},{\"@type\":\"Question\",\"name\":\"Do you charge per distributor seat?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"No. We understand that scale is critical in distributor networks. Licensing is based on your internal operational volume or internal seats, allowing infinite external distributor logins to maximize portal adoption.\"}}]}</script></div></section></main><footer class=\"ce-footer\"><div class=\"ce-footer-grid\"><div><div class=\"ce-footer-logo\">client<em>era</em></div><p class=\"ce-footer-desc\">The AI-Powered Commercial Operating System. One timeline. One truth. Zero gaps.</p><p style=\"font-size:11px;color:var(--text3);margin-top:14px\">Built for India. Compliant worldwide.</p></div><div><div class=\"ce-fc-h\">Platform</div><ul class=\"ce-fc-links\"><li><a href=\"/sales-ops\">Sales Ops</a></li><li><a href=\"/sales-management\">Management</a></li><li><a href=\"/customer-support\">Customer Support</a></li><li><a href=\"#\">Field Sales</a></li><li><a href=\"#\">Desk Sales</a></li><li><a href=\"#\">Operations</a></li><li><a href=\"#\">Distributor Portal</a></li></ul></div><div><div class=\"ce-fc-h\">Company</div><ul class=\"ce-fc-links\