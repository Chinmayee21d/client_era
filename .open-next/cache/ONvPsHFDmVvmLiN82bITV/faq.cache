{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/faq/layout,_N_T_/faq/page,_N_T_/faq"},"segmentPaths":["/_tree","/_full","/faq/__PAGE__","/faq","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"stylesheet\" href=\"/_next/static/css/53ebd3f615d9682f.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-4c9e6c08dcc7a301.js\"/><script src=\"/_next/static/chunks/4bd1b696-215e5051988c3dde.js\" async=\"\"></script><script src=\"/_next/static/chunks/794-4d0b7b700451cc43.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-c7dc77e60f3b3e6e.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/layout-ec2df61e02bf9503.js\" async=\"\"></script><script src=\"/_next/static/chunks/500-c99b8dfd3de17c86.js\" async=\"\"></script><script src=\"/_next/static/chunks/607-3b27179fa93ac4bd.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/faq/page-b15430530f38e066.js\" async=\"\"></script><link rel=\"preload\" href=\"https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;1,9..144,300;1,9..144,400&amp;family=Geist:wght@300;400;500;600;700&amp;display=swap\" as=\"style\"/><link rel=\"preconnect\" href=\"https://fonts.googleapis.com\"/><link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin=\"anonymous\"/><meta name=\"theme-color\" content=\"#0A1120\"/><title>Frequently Asked Questions | Client Era</title><meta name=\"description\" content=\"Answers to common questions about Client Era, our B2B distributor platform, implementation, and features.\"/><meta name=\"author\" content=\"ClientEra\"/><link rel=\"manifest\" href=\"/manifest.webmanifest\"/><meta name=\"keywords\" content=\"CRM,sales software,field sales,commercial OS,AI sales platform,pipeline management,sales intelligence\"/><meta name=\"creator\" content=\"ClientEra\"/><meta name=\"robots\" content=\"index, follow\"/><link rel=\"canonical\" href=\"https://clientera.aio/faq\"/><meta property=\"og:title\" content=\"ClientEra — The Unified Commercial OS\"/><meta property=\"og:description\" content=\"One platform for your entire commercial relationship — from the first conversation to the last payment.\"/><meta property=\"og:site_name\" content=\"ClientEra\"/><meta property=\"og:image\" content=\"https://www.clientera/logo.png\"/><meta property=\"og:image:width\" content=\"1200\"/><meta property=\"og:image:height\" content=\"630\"/><meta property=\"og:image:alt\" content=\"ClientEra Logo\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"ClientEra — The Unified Commercial OS\"/><meta name=\"twitter:description\" content=\"One platform for your entire commercial relationship — from the first conversation to the last payment.\"/><meta name=\"twitter:image\" content=\"https://www.clientera/logo.png\"/><link rel=\"icon\" href=\"/favicon.ico?603d046c9a6fdfbb\" type=\"image/x-icon\" sizes=\"16x16\"/><link rel=\"icon\" href=\"/logo.png\"/><link rel=\"apple-touch-icon\" href=\"/logo.png\"/><link href=\"https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;1,9..144,300;1,9..144,400&amp;family=Geist:wght@300;400;500;600;700&amp;display=swap\" rel=\"stylesheet\"/><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body><div hidden=\"\"><!--$--><!--/$--></div><div style=\"background-color:var(--navy);min-height:100vh;display:flex;flex-direction:column\"><nav id=\"ce-nav\" style=\"background:rgba(11, 22, 40, 0.4);backdrop-filter:blur(24px) saturate(1.8);border-bottom:1.5px solid rgba(255,255,255,0.04);height:72px;transition:all 0.4s cubic-bezier(0.16, 1, 0.3, 1);position:fixed;top:0;left:0;right:0;z-index:1000;display:flex;align-items:center;justify-content:space-between;padding:0 clamp(24px, 5vw, 84px)\"><a class=\"ce-nav-logo\" style=\"font-size:26px;letter-spacing:-0.8px;transition:transform 0.3s\" href=\"/\">client<em style=\"color:var(--gold);font-style:italic;font-weight:300\">era</em></a><div style=\"display:flex;align-items:center;gap:8px\" class=\"nav-desktop\"><ul style=\"display:flex;gap:4px;list-style:none\"><li><a style=\"font-size:13px;color:var(--text2);padding:8px 16px;border-radius:10px;transition:all 0.3s\" href=\"/#ai-layer\">AI Layer</a></li><li><a style=\"font-size:13px;color:var(--text2);padding:8px 16px;border-radius:10px;transition:all 0.3s\" href=\"/#pricing\">Pricing</a></li><li><a style=\"font-size:13px;color:var(--text2);padding:8px 16px;border-radius:10px;transition:all 0.3s\" href=\"/#comparison\">Why ClientEra</a></li></ul><div style=\"position:relative\"><button style=\"display:flex;align-items:center;gap:6px;padding:8px 16px;border-radius:10px;font-size:13px;font-weight:500;color:var(--text2);background:transparent;border:none;cursor:pointer;transition:all 0.3s\">Solutions<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down\" aria-hidden=\"true\" style=\"transform:none;transition:transform 0.3s\"><path d=\"m6 9 6 6 6-6\"></path></svg></button><div style=\"position:absolute;top:100%;right:0;transform:none;padding-top:12px;width:260px;opacity:0;pointer-events:none;transition:all 0.4s cubic-bezier(0.16, 1, 0.3, 1);visibility:hidden;z-index:1001\"><div style=\"background:rgba(11, 21, 38, 0.98);border-radius:22px;border:1.5px solid var(--border2);box-shadow:0 32px 80px rgba(0,0,0,0.5);padding:12px;display:flex;flex-direction:column;gap:4px;backdrop-filter:blur(30px)\"><a style=\"padding:10px 14px;border-radius:12px;text-deco